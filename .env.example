# GEMINI_API_KEY: Required for Gemini AI server-side calls.
GEMINI_API_KEY=''

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
VITE_APP_URL="MY_APP_URL"

# Optional: base URL for local Netlify functions during development
VITE_API_BASE_URL=""

VITE_FIREBASE_API_KEY=''

# EmailJS - Email invitation service
# Configure at: https://dashboard.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=''
VITE_EMAILJS_SERVICE_ID=''
VITE_EMAILJS_TEMPLATE_ID=''

# Daily pending bill reminders
# Runs in Netlify Scheduled Functions at 07:00 America/Fortaleza.
# FIREBASE_SERVICE_ACCOUNT_BASE64 should be a base64-encoded Firebase service account JSON.
FIREBASE_SERVICE_ACCOUNT_BASE64=''
REMINDER_TIME_ZONE='America/Fortaleza'
EMAILJS_PUBLIC_KEY=''
EMAILJS_PRIVATE_KEY=''
EMAILJS_SERVICE_ID=''
EMAILJS_REMINDER_TEMPLATE_ID=''
